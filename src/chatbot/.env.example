# .env.example
# Copy this to .env and fill in your values
# Never commit .env to git

# --- Required ---
GROQ_API_KEY=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

# --- Optional (defaults shown) ---
CHROMA_DB_PATH=./chatbot/chroma_db
CHROMA_COLLECTION=warif_knowledge
EMBEDDING_MODEL=paraphrase-multilingual-mpnet-base-v2

# Groq model options (all free tier):
#   llama-3.1-8b-instant   — fastest, good Arabic
#   llama-3.3-70b-versatile — slower, better quality
#   gemma2-9b-it            — Google model, strong multilingual
GROQ_MODEL=llama-3.1-8b-instant
